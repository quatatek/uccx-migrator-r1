            <refURL>/adminapi/skill/103</refURL>
          </skillNameUriPair>
          <weight>2</weight>
        </skillCompetency>
        <skillCompetency>
          <competencelevel>4</competencelevel>
          <skillNameUriPair name="Spanish Language">
