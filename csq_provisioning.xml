          </skillNameUriPair>
          <weight>2</weight>
        </skillCompetency>
        <selectionCriteria>Most Skilled</selectionCriteria>
      </skillGroup>
    </poolSpecificInfo>
  </csq>

  <!-- CSQ 3: Sales Queue with Multiple Skills -->
