<?xml version="1.0" encoding="UTF-8"?>
<!-- CSQ Provisioning XML for UCCX /adminapi/csq endpoint -->
<!-- References target skill IDs (101, 102, 103, etc.) from previously provisioned skills -->

<csqs>
  <!-- CSQ 1: Customer Service Queue -->
  <csq xmlns:xsi="https://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="csq.xsd">
    <self href="" rel="" type="" />
    <name>Customer Service Queue</name>
    <queueType>VOICE</queueType>
    <queueAlgorithm>FIFO</queueAlgorithm>
    <autoWork>true</autoWork>
    <wrapupTime>10</wrapupTime>
    <resourcePoolType>SKILL_GROUP</resourcePoolType>
    <serviceLevel>20</serviceLevel>
    <serviceLevelPercentage>80</serviceLevelPercentage>
    <poolSpecificInfo>
      <skillGroup>
        <skillCompetency>
          <competencelevel>5</competencelevel>
          <skillNameUriPair name="Customer Service">
            <refURL>/adminapi/skill/101</refURL>
          </skillNameUriPair>
          <weight>1</weight>
        </skillCompetency>
        <selectionCriteria>Longest Available</selectionCriteria>
      </skillGroup>
    </poolSpecificInfo>
  </csq>

  <!-- CSQ 2: Technical Support Queue -->
  <csq xmlns:xsi="https://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="csq.xsd">
